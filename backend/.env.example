# Geodata Backend Environment Variables
# Copy this file to .env.local and update values for your environment

# ============================================================================
# Database Configuration
# ============================================================================
# For local development with docker-compose
SUPABASE_JDBC_URL=jdbc:postgresql://localhost:5432/postgres?currentSchema=auth
SUPABASE_DATABASE_USER=postgres
SUPABASE_DATABASE_PASSWORD=admin

# For production (Supabase cloud)
# SUPABASE_JDBC_URL=jdbc:postgresql://aws-1-eu-west-3.pooler.supabase.com:5432/postgres?currentSchema=auth
# SUPABASE_DATABASE_USER=postgres.YOUR_PROJECT_ID
# SUPABASE_DATABASE_PASSWORD=YOUR_DB_PASSWORD

# ============================================================================
# JWT & Security
# ============================================================================
# Minimum 32 characters. In production, use a strong random string.
JWT_SECRET=change-me-in-prod-use-min-32-chars-string-not-this-default

# ============================================================================
# CORS Configuration
# ============================================================================
# Local development: React (5173), Frontend (80), Flutter (mobile)
ALLOWED-ORIGINS=http://localhost:5173,http://localhost:80,http://localhost:3000

# Production: your deployed frontend URL(s)
# ALLOWED-ORIGINS=https://example.com,https://app.example.com

# ============================================================================
# Inter-Service Communication (local development)
# ============================================================================
# Use service names in Kubernetes, localhost in docker-compose local dev
IDENTITY_SERVICE=localhost:8010
MAP_SERVICE=localhost:8020
BORROW_SERVICE=localhost:8030

# ============================================================================
# Logging & Profiling
# ============================================================================
# Use 'dev' for local development (DEBUG logs), 'prod' for production (INFO logs)
SPRING_PROFILES_ACTIVE=dev

# ============================================================================
# Default Credentials (LOCAL DEV ONLY)
# ============================================================================
# Change these immediately in production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123!
LIBRARIAN_USERNAME=librarian
LIBRARIAN_PASSWORD=librarian123!

# ============================================================================
# Optional: SonarQube & Analysis (local dev)
# ============================================================================
SONAR_HOST_URL=http://localhost:9000
SONAR_LOGIN=admin
SONAR_PASSWORD=admin

# ============================================================================
# Email Configuration (for notifications)
# ============================================================================
# Using Mailpit for local testing
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@geodata.local
MAIL_USERNAME=
MAIL_PASSWORD=
